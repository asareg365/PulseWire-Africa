{
  "entities": {
    "author": {
      "title": "Author",
      "description": "User profile with role-based access control inside the newsroom.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "bio": { "type": "string" },
        "avatar": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "editor", "contributor"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role", "createdAt"]
    },
    "article": {
      "title": "Article",
      "description": "A news article with multi-category support, tags, view count, and status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "summary": { "type": "string" },
        "content": { "type": "string" },
        "featuredImage": { "type": "string" },
        "category": { "type": "string" },
        "tags": { "type": "array" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" },
        "publishedAt": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "published", "scheduled"] },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "shareCount": { "type": "number" },
        "isSponsored": { "type": "boolean" },
        "isAffiliate": { "type": "boolean" }
      },
      "required": ["id", "title", "slug", "summary", "content", "category", "authorId", "createdAt", "status"]
    },
    "comment": {
      "title": "Comment",
      "description": "An article comment submitted by a logged-in user or guest.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "articleId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorAvatar": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string" },
        "approved": { "type": "boolean" }
      },
      "required": ["id", "articleId", "authorName", "content", "createdAt", "approved"]
    },
    "ad": {
      "title": "Ad Placement",
      "description": "An advertisement space for monetization tracking impressions and clicks.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["banner", "sidebar", "in-article", "sticky"] },
        "imageUrl": { "type": "string" },
        "link": { "type": "string" },
        "active": { "type": "boolean" },
        "impressions": { "type": "number" },
        "clicks": { "type": "number" }
      },
      "required": ["id", "title", "type", "imageUrl", "link", "active"]
    },
    "newsletter": {
      "title": "Newsletter Subscription",
      "description": "Email address signed up for daily/weekly newsletters.",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "subscribedAt": { "type": "string" }
      },
      "required": ["email", "subscribedAt"]
    },
    "contact": {
      "title": "Contact Message",
      "description": "Message submitted via the contact form.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "submittedAt": { "type": "string" }
      },
      "required": ["name", "email", "subject", "message", "submittedAt"]
    }
  },
  "firestore": {
    "/authors/{authorId}": {
      "schema": "author",
      "description": "Author profiles with permissions"
    },
    "/articles/{articleId}": {
      "schema": "article",
      "description": "Published and draft stories"
    },
    "/articles/{articleId}/comments/{commentId}": {
      "schema": "comment",
      "description": "User feedback on articles"
    },
    "/ads/{adId}": {
      "schema": "ad",
      "description": "Advertising display entities"
    },
    "/newsletter/{emailHash}": {
      "schema": "newsletter",
      "description": "Subscribed readers"
    },
    "/contacts/{contactId}": {
      "schema": "contact",
      "description": "User queries"
    }
  }
}
