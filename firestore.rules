rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net: Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Rules for Authors/Users
    match /authors/{authorId} {
      allow read: if true;
      allow write: if true;
    }

    // Rules for Articles
    match /articles/{articleId} {
      allow read: if true;
      allow write: if true;

      // Rules for Subcollection Comments
      match /comments/{commentId} {
        allow read: if true;
        allow write: if true;
      }
    }

    // Rules for Ads
    match /ads/{adId} {
      allow read: if true;
      allow write: if true;
    }

    // Rules for Newsletter subscriptions
    match /newsletter/{emailHash} {
      allow read: if true;
      allow write: if true;
    }
  }
}
